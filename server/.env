# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/nexuschat

# JWT Configuration
JWT_SECRET=development_fallback_jwt_secret_key_long_enough_to_be_secure_12345
JWT_EXPIRE=7d

# SMTP Configuration (Nodemailer)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=mock_user
EMAIL_PASS=mock_pass
EMAIL_FROM=noreply@nexuschat.com

# Cloudinary Configuration (Media Storage)
CLOUDINARY_CLOUD_NAME=mock_cloud
CLOUDINARY_API_KEY=mock_key
CLOUDINARY_API_SECRET=mock_secret

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
